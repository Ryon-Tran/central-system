<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- ========== CRON JOB 1: Check SSL Expiry ========== -->
        <record id="cron_check_ssl_expiry" model="ir.cron">
            <field name="name">IT Hub: Check SSL Certificate Expiry</field>
            <field name="model_id" ref="model_project_project"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_ssl_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="doall" eval="False"/>
        </record>
        
        <!-- ========== CRON JOB 2: Check Failed Pipelines ========== -->
        <record id="cron_check_pipeline_status" model="ir.cron">
            <field name="name">IT Hub: Check Failed Pipelines</field>
            <field name="model_id" ref="model_project_project"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_pipeline_status()</field>
            <field name="interval_number">6</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="doall" eval="False"/>
        </record>
        
        <!-- ========== CONFIG PARAMETERS ========== -->
        <record id="config_param_chatwoot_base_url" model="ir.config_parameter">
            <field name="key">chatwoot.base_url</field>
            <field name="value">https://app.chatwoot.com</field>
        </record>
        
        <record id="config_param_n8n_cloudflare_webhook" model="ir.config_parameter">
            <field name="key">n8n.cloudflare_webhook_url</field>
            <field name="value">https://your-n8n.com/webhook/cloudflare-manual-purge</field>
        </record>
        
    </data>
</odoo>